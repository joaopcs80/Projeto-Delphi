  inherited QryListagem: TZQuery
    SQL.Strings = (
      'SELECT p.produtoId,'
      '       p.nome,'
      #9'     p.descricao,'
      #9'     p.valor,'
      #9'     p.quantidade,'
      '                     p.foto,'
      #9'     p.categoriaId,'
      #9'     c.descricao As DescricaoCategoria'
      '  FROM produtos as p'
      '  LEFT JOIN categorias as c on c.categoriaId = p.categoriaId')
    Left = 435
    Top = 53
    object QryListagemprodutoId: TIntegerField
      Alignment = taLeftJustify
